# ============================================================
# AI Risk Council — Environment Variables
# Copy this file to .env and fill in your credentials.
# Never commit your actual .env file to version control.
# ============================================================

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Gemini ─────────────────────────────────────────────
GOOGLE_API_KEY=AIza...

# ── OpenRouter ───────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
# Optional: sent in HTTP-Referer and X-Title headers
OPENROUTER_SITE_URL=https://your-site.example.com
OPENROUTER_SITE_NAME=AI Risk Council

# ── Ollama (local) ────────────────────────────────────────────
# Default: http://localhost:11434
# Change if Ollama is running on a different host or port.
OLLAMA_BASE_URL=http://localhost:11434
