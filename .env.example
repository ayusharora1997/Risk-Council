# ============================================================
# AI Risk Council — Environment Variables
# ============================================================
# 1. Copy this file:   cp .env.example .env   (Mac/Linux)
#                      copy .env.example .env  (Windows)
# 2. Fill in the keys for the providers you want to use.
# 3. NEVER commit your .env — it is in .gitignore already.
# ============================================================

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ── OpenRouter ────────────────────────────────────────────────────────────────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional — sent as HTTP-Referer / X-Title headers
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=AI Risk Council

# ── Ollama (local models — no key required) ───────────────────────────────────
# Ollama runs on your machine. Install: https://ollama.com/download
# Change the URL only if Ollama is on a different host/port.
OLLAMA_BASE_URL=http://localhost:11434
